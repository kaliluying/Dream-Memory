{
  "models": {
    "primary": {
      "provider": "openai",
      "model": "gpt-4.1",
      "api_key": "",
      "api_key_env": "OPENAI_API_KEY",
      "base_url": null,
      "timeout_seconds": 60
    }
  },
  "model_policy": {
    "default_profile": "primary",
    "fallback_chain": ["primary"],
    "retry": {
      "max_attempts": 3,
      "initial_delay_seconds": 1.0,
      "backoff_factor": 2.0,
      "max_delay_seconds": 8.0,
      "retry_on_status": [429, 500, 502, 503, 504],
      "retry_on_timeout": true,
      "switch_model_on_retry": false
    },
    "allow_rules_fallback": false
  },
  "invoke_model": true,
  "mode": "ai",
  "output_dir": ".dream-memory",
  "imports_output_dir": ".dream-memory/imports",
  "memory_cards": ".dream-memory/memory_cards.jsonl",
  "context_limit": 12,
  "context_format": "json",
  "auto_export": false,
  "export_target": "both",
  "export_scope": "project",
  "export_output_dir": null,
  "codex_home": "~/.codex",
  "claude_home": "~/.claude",
  "claude_state": "~/.claude.json"
}
